# ============================================================
# SEO · we360.ai — Environment Variables
# Copy to .env.local and fill in real values.
# .env.local is gitignored and never committed.
# ============================================================

# -- Supabase ------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — SERVER ONLY, never ship to client.
SUPABASE_SERVICE_ROLE_KEY=

# -- Google OAuth --------------------------------------------
# Configured in Supabase Dashboard → Auth → Providers → Google.
# Only @we360.ai accounts are allowed (domain guard in /app/auth/callback).

# -- App -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -- Cron security (Vercel Cron auth) ------------------------
# Generate with: openssl rand -base64 32
CRON_SECRET=

# -- Apify (keyword discovery) -------------------------------
APIFY_TOKEN=
APIFY_ACTOR_ID=trovevault/keyword-opportunity-finder

# -- Google APIs ---------------------------------------------
# Service account JSON — single-line (base64 is fine too).
GOOGLE_SERVICE_ACCOUNT_JSON=
# PageSpeed Insights (free — Google Cloud Console)
PAGESPEED_API_KEY=

# -- AI providers (NOT server-stored — BYOK via UI modal) ----
# CLAUDE_API_KEY=
# OPENAI_API_KEY=
